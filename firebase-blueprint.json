{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "description": { "type": "string", "description": "Product description" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "List of image URLs" },
        "category": { "type": "string", "description": "Product category (e.g., Camisas, Shorts, Moletons, Acessórios)" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "Available sizes (P, M, G, GG)" },
        "stock": { "type": "number", "description": "Current stock quantity" },
        "featured": { "type": "boolean", "description": "Whether the product is featured on the home page" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "price", "description", "images", "category", "sizes", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "phone": { "type": "string" },
            "course": { "type": "string" }
          },
          "required": ["name", "phone"]
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "size": { "type": "string" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "paymentMethod": { "type": "string", "enum": ["pix"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customer", "items", "total", "status", "paymentMethod", "createdAt"]
    }
  },
  "firestore": {
    "/products": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/orders": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
